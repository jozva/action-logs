NODE_ENV=development
PORT=8080
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/gidy-security-logs?retryWrites=true&w=majority
CORS_ORIGIN=http://localhost:5173
LOG_LEVEL=info
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
UPLOAD_RATE_LIMIT_MAX=10
BODY_LIMIT=5mb
UPLOAD_MAX_RECORDS=10000
